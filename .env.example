# Market data provider selection: yfinance | dhan | finnhub | mock
# Default is yfinance (keyless, covers NSE + US).
MARKET_DATA_PROVIDER=yfinance

# Dhan credentials (only used when MARKET_DATA_PROVIDER=dhan)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=paste_dhan_access_token_here

# Finnhub key (only used when MARKET_DATA_PROVIDER=finnhub; /stock/candle requires a paid plan)
FINNHUB_API_KEY=paste_finnhub_api_key_here

# Set SCAN_DEBUG=1 to print per-symbol indicator state every scan (also works
# under the long-running scheduler, not just --run-once). CLI --debug overrides.
# SCAN_DEBUG=1

# In-memory candle cache TTL (seconds). 0 disables caching. Default 600 (10 min).
# SCAN_CACHE_TTL=600