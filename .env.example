# Market data provider selection: yfinance | dhan | mock
# Default is yfinance (keyless, covers NSE + US).
MARKET_DATA_PROVIDER=yfinance

# Dhan credentials (only used when MARKET_DATA_PROVIDER=dhan)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=paste_dhan_access_token_here

# Strategy selection. Currently supported: swing. Default: swing.
SCAN_STRATEGY=swing

# Gemini model used for both the analyst layer and the Gemini news
# client. Default: gemini-2.5-flash (best flash-tier model; comfortably
# inside free-tier limits for this workload).
# GEMINI_MODEL=gemini-2.5-flash

# News source. gemini = Google Search grounding via the existing Gemini
# key (no extra vendor); perplexity = sonar via Perplexity API (requires
# Perplexity API credits — Pro subscription does NOT include them); none
# = skip the news layer. Default: gemini.
# NEWS_SOURCE=gemini

# Set SCAN_DEBUG=1 to print per-symbol indicator state every scan (also works
# under the long-running scheduler, not just --run-once). CLI --debug overrides.
# SCAN_DEBUG=1

# In-memory candle cache TTL (seconds). 0 disables caching. Default 600 (10 min).
# SCAN_CACHE_TTL=600
# Optional: path used by --healthcheck when --watchlist is not passed.
# In production, set this to /opt/swing_scanner/watchlist.txt.
# SCAN_WATCHLIST_PATH=/opt/swing_scanner/watchlist.txt
# Timezone used for scheduler timestamps/logging.
APP_TIMEZONE=Asia/Kolkata
# Emit JSON logs for journald/aggregation.
LOG_STRUCTURED=1
# Optional heartbeat / failure ping after every scan.
# TELEGRAM_HEARTBEAT_ENABLED=1

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram credentials
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
